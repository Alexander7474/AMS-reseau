# Auto config gen by /var/www/html/src/scripts/cfg-dhcp.sh
# The loopback network interface
auto lo
iface lo inet loopback 

# The primary network interface NAT
allow-hotplug eth0
iface eth0 inet dhcp

# Internal network
allow-hotplug eth1
iface eth1 inet static
address 192.168.10.2
netmask 255.255.255.0

# FAI network
allow-hotplug eth2
iface eth2 inet static
address 10.10.10.2
netmask 255.255.255.0
#Config modifier par network.php
